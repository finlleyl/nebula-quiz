# Copy to .env and fill in. .env is gitignored.

# Backend ---------------------------------------------------------
HTTP_ADDR=:8080
DATABASE_URL=postgres://nebula:nebula@localhost:5432/nebula?sslmode=disable
REDIS_URL=redis://localhost:6379

# S3 / MinIO (dev defaults match deploy/docker-compose.dev.yml)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nebula
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniominio

# JWT (generate a long random string for real deployments)
JWT_SECRET=change-me-in-real-deployments

# Frontend --------------------------------------------------------
VITE_API_BASE=/api/v1
VITE_WS_URL=/ws
