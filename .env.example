# Copy to .env and fill in. .env is gitignored.

# Backend ---------------------------------------------------------
HTTP_ADDR=:8080
APP_ENV=development
DATABASE_URL=postgres://nebula:nebula@localhost:5432/nebula?sslmode=disable
REDIS_URL=redis://localhost:6379

# S3 / MinIO (dev defaults match deploy/docker-compose.dev.yml)
S3_ENDPOINT=localhost:9000
S3_BUCKET=nebula-images
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniominio
S3_USE_SSL=false
# Public URL clients hit to fetch images (dev = same MinIO endpoint).
S3_PUBLIC_BASE_URL=http://localhost:9000

# Auth ------------------------------------------------------------
# JWT_SECRET must be >= 32 bytes of random entropy (NOT a passphrase).
# Generate: openssl rand -base64 48
JWT_SECRET=dev-only-please-change-me-to-a-proper-32plus-byte-secret
JWT_ACCESS_TTL=15m
REFRESH_TTL=720h
ALLOWED_ORIGINS=http://localhost:5173

# Frontend --------------------------------------------------------
VITE_API_BASE=/api/v1
VITE_WS_URL=/ws
